{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "entrypoints/**/*",
    "lib/**/*",
    "tests/**/*",
    "*.ts",
    "vitest.config.ts",
    "playwright.config.ts"
  ]
}
