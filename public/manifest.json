{
    "name": "tab manager",
    "description": "tab manager",
    "version": "1.3",
    "background": {
        "service_worker": "service_worker.js",
        "type": "module"
    },
    "icons": {
        "128": "tab.png"
    },
    "action": {
        "default_title": "Click to open panel"
    },
    "manifest_version": 3,
    "permissions": [
        "activeTab",
        "windows",
        "tabGroups",
        "tabs",
        "webNavigation",
        "alarms",
        "unlimitedStorage",
        "sidePanel",
        "history",
        "storage",
        "scripting"
    ],
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "host_permissions": [
        "<all_urls>"
    ],
    "content_scripts": [
        {
            "matches": ["http://*/*", "https://*/*"],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ]
}
