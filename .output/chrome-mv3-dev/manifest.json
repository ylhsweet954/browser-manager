{
  "manifest_version": 3,
  "name": "tab manager",
  "description": "tab manager",
  "version": "1.3",
  "icons": {
    "128": "tab.png"
  },
  "permissions": [
    "activeTab",
    "windows",
    "tabGroups",
    "tabs",
    "webNavigation",
    "alarms",
    "unlimitedStorage",
    "sidePanel",
    "history",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://*/*",
    "https://*/*",
    "http://localhost/*"
  ],
  "action": {
    "default_title": "Click to open panel"
  },
  "commands": {
    "wxt:reload-extension": {
      "description": "Reload the extension during development",
      "suggested_key": {
        "default": "Alt+R"
      }
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval' http://localhost:3000; object-src 'self';",
    "sandbox": "script-src 'self' 'unsafe-inline' 'unsafe-eval' http://localhost:3000; sandbox allow-scripts allow-forms allow-popups allow-modals; child-src 'self';"
  }
}